APP_ENV=local
# Local Docker/mock payments default. On a server use your public HTTPS URL.
APP_BASE_URL=http://localhost:8000

# Local Python default. Docker Compose overrides this to /app/data/bot.sqlite3.
DATABASE_PATH=./data/bot.sqlite3

BOT_TOKEN=123456:replace-me
TELEGRAM_GROUP_ID=-1001234567890
TELEGRAM_WEBHOOK_SECRET=replace-with-random-token

ADMIN_IDS=123456789,987654321
ADMIN_USERNAMES=admin_username

LAVA_BASE_URL=https://api.lava.example
LAVA_SHOP_ID=replace-me
LAVA_API_KEY=replace-me
LAVA_WEBHOOK_SECRET=replace-me

# Use lava for production, mock for local checks without Lava.
PAYMENT_PROVIDER=lava
# Legacy explicit switch is also supported:
MOCK_PAYMENTS_ENABLED=false

SCHEDULER_INTERVAL_SECONDS=60
PENDING_PAYMENT_CHECK_SECONDS=300
