# Production settings for adlan.bot.rmzn.net via Caddy -> API port 8000.
APP_ENV=production
APP_BASE_URL=https://adlan.bot.rmzn.net

# Docker Compose overrides this to /app/data/bot.sqlite3.
# Keep this value for local runs outside Docker.
DATABASE_PATH=./data/bot.sqlite3

# Telegram
BOT_TOKEN=paste_telegram_bot_api_token_here
TELEGRAM_GROUP_ID=paste_private_group_id_here
TELEGRAM_WEBHOOK_SECRET=replace-with-random-token

# Telegram admins. IDs are comma-separated numbers. Usernames are comma-separated without @.
ADMIN_IDS=paste_admin_telegram_id_1,paste_admin_telegram_id_2
ADMIN_USERNAMES=paste_admin_username_1,paste_admin_username_2

# Lava Business
LAVA_BASE_URL=https://api.lava.ru
LAVA_SHOP_ID=paste_lava_shop_id_here
LAVA_SECRET_KEY=paste_lava_secret_key_here
LAVA_ADDITIONAL_KEY=paste_lava_additional_key_here

# Real payments through Lava.
PAYMENT_PROVIDER=lava
MOCK_PAYMENTS_ENABLED=false

SCHEDULER_INTERVAL_SECONDS=60
PENDING_PAYMENT_CHECK_SECONDS=300
